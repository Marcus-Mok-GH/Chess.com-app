run = "npm run dev:all"
modules = ["nodejs-20", "web", "python-3.12"]
hidden = [".config", "package-lock.json"]
entrypoint = "index.html"

[nix]
channel = "stable-25_05"
packages = ["awscli2", "azure-cli", "bubblewrap", "google-cloud-sdk-gce", "ollama", "socat", "unzipNLS", "uv"]

