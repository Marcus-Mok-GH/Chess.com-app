{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm ci --ignore-scripts --no-audit --no-fund --legacy-peer-deps --workspaces=false",
  "framework": null,
  "outputDirectory": "dist",
  "regions": [
    "iad1"
  ],
  "functions": {
    "api/[...path].js": {
      "includeFiles": "server/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
