{
  "installCommand": "pnpm install --ignore-scripts",
  "buildCommand": "pnpm run typecheck && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/chess run build && cp -r artifacts/chess/dist/public ./dist",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "{artifacts/api-server/src/**,node_modules/stockfish/bin/stockfish-18-lite-single.js,node_modules/stockfish/bin/stockfish-18-lite-single.wasm}",
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
