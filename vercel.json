{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm ci --include=dev --ignore-scripts --no-audit --no-fund --legacy-peer-deps --no-workspaces",
  "framework": null,
  "outputDirectory": "dist",
  "regions": [
    "iad1"
  ],
  "functions": {
    "api/[...path].js": {
      "includeFiles": "{server/**,node_modules/stockfish/bin/**}",
      "maxDuration": 15
    }
  },
  "env": {
    "FUNCTION_TIMEOUT_MS": "12000"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
