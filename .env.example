# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/chess_db

# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Authentication
# Get your project URL and anon key at https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Mistral AI API Key (for AI Coach feature)
MISTRAL_API_KEY=your-mistral-api-key

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Vite/Next.js API URL
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=/

# Optional: Server URL for client-side
VITE_SERVER_URL=http://localhost:3001

# Socket.io configuration
VITE_SOCKET_URL=http://localhost:3001
VITE_SOCKET_PATH=/socket.io
FORCE_POLLING=false

# Replit-specific environment variables (auto-set by Replit)
REPL_SLUG=your-repl-slug
REPL_OWNER=your-repl-owner
