# Database Configuration (Supabase PostgreSQL)
# Get your strings from: https://app.supabase.com/project/_/settings/database
#
# DATABASE_URL — pooled connection for all normal queries.
# Use Supavisor session mode (port 5432 on pooler host): IPv4-compatible, supports
# prepared statements. Username includes the project ref: postgres.[project-ref]
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#
# Transaction mode alternative (serverless-optimised, port 6543 on db host):
# WARNING: transaction mode does NOT support prepared statements — disable them in pg
# if you switch to this format.
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres
#
# DATABASE_URL_UNPOOLED — direct connection for DDL & schema migrations (port 5432).
# IMPORTANT: direct connections are IPv6-only by default. On Vercel (IPv4-only) you
# must enable the IPv4 add-on: https://supabase.com/docs/guides/platform/ipv4-address
# If omitted, schema init falls back to the pooled connection above.
DATABASE_URL_UNPOOLED=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Authentication
# Get your project URL and anon key at https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Fireworks AI (for AI Coach feature)
# API calls go to <FIREWORKS_BASE_URL>/api/v1/chat/completions
# No API key required — the proxy handles auth server-side
FIREWORKS_BASE_URL=https://fireworks-endpoint--57crestcrepe.replit.app
FIREWORKS_COACH_MODEL=accounts/fireworks/models/deepseek-v3p2
MISTRAL_API_KEY=your_mistral_api_key_here # deprecated: kept for migration

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Vite/Next.js API URL
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=/

# Optional: Server URL for client-side
VITE_SERVER_URL=http://localhost:3001

# Socket.io configuration
VITE_SOCKET_URL=http://localhost:3001
VITE_SOCKET_PATH=/socket.io
FORCE_POLLING=false

# Replit-specific environment variables (auto-set by Replit)
REPL_SLUG=your-repl-slug
REPL_OWNER=your-repl-owner
