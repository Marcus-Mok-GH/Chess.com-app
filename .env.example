# ── Required ──────────────────────────────────────────────────────────────────

# Database (Neon, Supabase, or any PostgreSQL)
# Use a pooled connection string for all normal queries.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# DATABASE_URL_UNPOOLED — direct (non-pooled) connection used only for schema
# migrations on startup. Defaults to DATABASE_URL if omitted; only set this
# when your provider requires a separate URL for DDL (e.g. Neon, Supabase).
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/dbname

# Neon Auth — required for user sign-in via OTP
# Copy from: Neon Console → your project → Auth tab
VITE_NEON_AUTH_URL=https://your-neon-auth-url

# ── Production only ───────────────────────────────────────────────────────────

# Frontend origin used for CORS and SPA redirects.
# Defaults to http://localhost:5173 in development.
# On Vercel, VERCEL_URL is read automatically — only set this if you have a
# custom domain or deploy to a non-Vercel host.
FRONTEND_URL=https://your-app.example.com

# Socket.IO server URL — only needed when the Socket.IO server runs on a
# different host than the frontend (e.g. Vercel frontend + Railway backend).
# Leave unset for same-host or local dev (the Vite proxy handles it).
VITE_SOCKET_URL=https://your-socket-server.example.com

# ── Optional overrides ────────────────────────────────────────────────────────

# Server port. Defaults to 3001; most platforms set PORT automatically.
# PORT=3001

# AI Coach (Fireworks) — hardcoded defaults are used when these are unset.
# FIREWORKS_BASE_URL=https://fireworks-endpoint--57crestcrepe.replit.app
# FIREWORKS_COACH_MODEL=accounts/fireworks/models/deepseek-v3p2
# FIREWORKS_API_KEY=   # only required if the Fireworks proxy enforces auth

# Force Socket.IO into HTTP long-polling mode (disables WebSocket upgrade).
# Useful when the deployment environment blocks WebSocket connections.
# FORCE_POLLING=true
