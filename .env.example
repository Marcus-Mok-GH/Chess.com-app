# Database Configuration (PostgreSQL)
# For production, use a proper connection string with SSL
# Example: postgresql://username:password@hostname:5432/database?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/chess_db

# Server Configuration
PORT=3001
NODE_ENV=development

# Mistral AI API Key (for AI Coach feature)
# Get your API key at https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key

# Frontend URL for CORS
# For local development: http://localhost:5173
# For production (Vercel): https://your-domain.vercel.app
# For production (Netlify): https://your-site.netlify.app
FRONTEND_URL=http://localhost:5173

# Vite/Next.js API URL
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=/

# Server URL for client-side (set this for production deployment)
# Vite automatically uses @vercel/project-url when deployed to Vercel
# VITE_SERVER_URL=http://localhost:3001

# Socket.io configuration
# Base URL (protocol + host). In production you can usually omit this to use same-origin.
# VITE_SOCKET_URL=http://localhost:3001
# Path (defaults to /socket.io)
# VITE_SOCKET_PATH=/socket.io
# Optional transport override (comma-separated)
# VITE_SOCKET_TRANSPORTS=websocket,polling
# Server-side override to force polling only (some hosts require it)
# FORCE_POLLING=false

# Replit-specific environment variables (auto-set by Replit)
# You don't need to set these manually
# REPL_SLUG=your-repl-slug
# REPL_OWNER=your-repl-owner
