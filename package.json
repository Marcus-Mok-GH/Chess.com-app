{
  "name": "react-javascript",
  "version": "1.1.39",
  "author": "",
  "description": "React Chess Application with Real-time Multiplayer",
  "keywords": [
    "chess",
    "react",
    "socket.io",
    "multiplayer"
  ],
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:vite": "vite --port 5173 --host",
    "dev:server": "node server/index.js",
    "dev:all": "node server/index.js & vite --port 5173 --host",
    "build": "vite build",
    "build:server": "node server/index.js",
    "preview": "vite preview --port 5173",
    "preview:all": "npm run preview & npm run start:server",
    "start": "node server/index.js",
    "start:server": "node server/index.js",
    "start:vite": "vite preview --port 5173 --host",
    "start:all": "npm run start:server & npm run start:vite & wait",
    "lint": "vite build --mode production 2>&1 || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:setup": "node --loader ts-node/esm tests/setup.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "db:setup": "node server/db/setup.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^2.1.8",
    "whatwg-fetch": "^3.6.20"
  },
  "type": "module",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@supabase/supabase-js": "^2.105.3",
    "@vercel/analytics": "^2.0.1",
    "chess.js": "^1.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "pg": "^8.17.2",
    "playwright": "^1.58.1",
    "puter": "^1.0.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stockfish.js": "^10.0.2",
    "vercel": "^50.14.0",
    "ws": "^8.19.0"
  }
}
