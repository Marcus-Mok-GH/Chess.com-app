{
  "name": "react-javascript",
  "version": "1.0.0",
  "author": "",
  "description": "React Chess Application with Real-time Multiplayer",
  "keywords": [
    "chess",
    "react",
    "socket.io",
    "multiplayer"
  ],
  "license": "ISC",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "npm run dev:all",
    "dev:vite": "vite --port 5173 --host",
    "dev:server": "node server/index.js",
    "dev:all": "node server/index.js & vite --port 5173 --host",
    "build": "vite build",
    "build:server": "node server/index.js",
    "preview": "vite preview --port 5173",
    "preview:all": "npm run preview & npm run start:server",
    "start": "node server/index.js",
    "start:server": "node server/index.js",
    "start:vite": "vite preview --port 5173 --host",
    "start:all": "npm run start:server & npm run start:vite & wait",
    "lint": "vite build --mode production 2>&1 || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:setup": "node --loader ts-node/esm tests/setup.js"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^2.1.8",
    "whatwg-fetch": "^3.6.20"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.34",
    "@neondatabase/serverless": "^1.0.2",
    "@openai/codex": "^0.98.0",
    "@sourcegraph/amp": "^0.0.1770682056-gad6470",
    "bcryptjs": "^3.0.3",
    "chess.js": "^1.4.0",
    "claude-flow": "^3.1.0-alpha.3",
    "codebuff": "^1.0.603",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "next": "^16.1.6",
    "opencode-ai": "1.1.53",
    "pg": "^8.17.2",
    "playwright": "^1.58.1",
    "puter": "^1.0.0",
    "react": "^18.3.1",
    "react-chessboard": "^4.7.3",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stockfish.js": "^10.0.2",
    "vercel": "^50.13.2",
    "ws": "^8.19.0"
  }
}
